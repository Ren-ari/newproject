<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>전국 날씨 위젯</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background-color: #f5f5f5;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        }

        .widget-container {
            display: flex;
            height: 384px;
        }

        /* 날씨 정보 영역 */
        .weather-info {
            width: 64px;
            background-color: black;
            border-radius: 8px 0 0 8px;
            padding: 8px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            color: white;
        }

        .weather-section {
            text-align: center;
        }

        .location-name {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .weather-icon {
            width: 24px;
            height: 24px;
            margin: 0 auto 4px;
        }

        .temperature {
            font-size: 18px;
            font-weight: bold;
        }

        .humidity {
            font-size: 12px;
            color: #cbd5e1;
            margin-top: 4px;
        }

        .humidity-icon {
            width: 16px;
            height: 16px;
            margin: 0 auto 4px;
        }

        .ozone-section {
            text-align: center;
        }

        .ozone-label {
            font-size: 12px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .ozone-icon {
            width: 24px;
            height: 24px;
            margin: 0 auto 4px;
        }

        .ozone-value {
            font-size: 14px;
            font-weight: bold;
        }

        .ozone-unit {
            font-size: 12px;
            color: #cbd5e1;
        }

        /* 지역 선택 영역 */
        .location-selector {
            width: 160px;
            background-color: white;
            border-radius: 0 8px 8px 0;
            padding: 8px;
            border-left: 1px solid #e5e7eb;
        }

        .selector-title {
            font-size: 12px;
            font-weight: 600;
            color: #4b5563;
            margin-bottom: 8px;
        }

        .select-wrapper {
            position: relative;
            margin-bottom: 8px;
        }

        select {
            width: 100%;
            padding: 4px;
            font-size: 12px;
            border: 1px solid #d1d5db;
            border-radius: 4px;
            appearance: none;
            cursor: pointer;
            background-color: white;
        }

        .select-icon {
            position: absolute;
            right: 8px;
            top: 50%;
            transform: translateY(-50%);
            width: 12px;
            height: 12px;
            pointer-events: none;
            color: #9ca3af;
        }

        /* SVG 아이콘 스타일 */
        .icon {
            fill: currentColor;
        }
    </style>
</head>
<body>
    <div class="widget-container">
        <!-- 날씨 정보 영역 -->
        <div class="weather-info">
            <div class="weather-section">
                <div class="location-name">신사동</div>
                <!-- 구름 아이콘 -->
                <svg class="weather-icon icon" viewBox="0 0 24 24">
                    <path d="M17.5 21H9a6 6 0 1 1 5.9-7h2.6a4.5 4.5 0 1 1 0 7Z"/>
                </svg>
                <div class="temperature">22°C</div>
                <div class="humidity">
                    <!-- 습도 아이콘 -->
                    <svg class="humidity-icon icon" viewBox="0 0 24 24">
                        <path d="M12 21a7 7 0 0 1-7-7c0-2.1 1.4-4.1 2.8-5.6C9.2 6.8 12 4 12 4s2.8 2.8 4.2 4.4C17.6 9.9 19 11.9 19 14a7 7 0 0 1-7 7Z"/>
                    </svg>
                    <span>45%</span>
                </div>
            </div>
            
            <div class="ozone-section">
                <div class="ozone-label">오존</div>
                <!-- 경고 아이콘 -->
                <svg class="ozone-icon icon" viewBox="0 0 24 24">
                    <path d="M12 9v4m0 3h.01M10.7 3h2.6c.5 0 1 .2 1.4.6l6.7 6.7c.4.4.6.9.6 1.4v2.6c0 .5-.2 1-.6 1.4l-6.7 6.7c-.4.4-.9.6-1.4.6h-2.6c-.5 0-1-.2-1.4-.6l-6.7-6.7c-.4-.4-.6-.9-.6-1.4v-2.6c0-.5.2-1 .6-1.4l6.7-6.7c.4-.4.9-.6 1.4-.6z"/>
                </svg>
                <div class="ozone-value">0.032</div>
                <div class="ozone-unit">ppm</div>
            </div>
        </div>

        <!-- 지역 선택 영역 -->
        <div class="location-selector">
            <div class="selector-title">지역 선택</div>
            
            <div class="select-wrapper">
                <select id="city">
                    <option value="서울특별시">서울특별시</option>
                    <option value="부산광역시">부산광역시</option>
                    <option value="인천광역시">인천광역시</option>
                </select>
                <svg class="select-icon" viewBox="0 0 24 24">
                    <path d="m6 9 6 6 6-6"/>
                </svg>
            </div>

            <div class="select-wrapper">
                <select id="district">
                    <option value="강남구">강남구</option>
                    <option value="서초구">서초구</option>
                    <option value="종로구">종로구</option>
                </select>
                <svg class="select-icon" viewBox="0 0 24 24">
                    <path d="m6 9 6 6 6-6"/>
                </svg>
            </div>

            <div class="select-wrapper">
                <select id="dong">
                    <option value="신사동">신사동</option>
                    <option value="압구정동">압구정동</option>
                    <option value="청담동">청담동</option>
                </select>
                <svg class="select-icon" viewBox="0 0 24 24">
                    <path d="m6 9 6 6 6-6"/>
                </svg>
            </div>
        </div>
    </div>

    <script>
        // 실제 구현 시 필요한 JavaScript 코드
        // 1. 드롭다운 선택 시 이벤트 처리
        // 2. 날씨 데이터 API 호출
        // 3. 실시간 데이터 업데이트
    </script>
</body>
</html>
